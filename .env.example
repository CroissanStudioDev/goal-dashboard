# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goal_dashboard

# Encryption key for storing bank tokens (required, min 32 chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=your-32-character-secret-key-here-change-me

# Basic Auth (optional - if not set, app is open)
AUTH_USERNAME=
AUTH_PASSWORD=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Точка Bank OAuth 2.0 (optional)
# Register app at: https://i.tochka.com/bank/services/m/integration/new
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
TOCHKA_REDIRECT_URI=http://localhost:3000/api/auth/tochka/callback

# Т-Банк mTLS certificates (optional, for production)
# Download from T-Business dashboard
TBANK_CERT_PATH=
TBANK_KEY_PATH=
TBANK_CERT_PASSWORD=
