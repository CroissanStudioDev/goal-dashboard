# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goal_dashboard

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sync protection (generate with: openssl rand -hex 32)
CRON_SECRET=your-secret-here

# Точка Bank (OAuth 2.0)
# Register app at: https://i.tochka.com/bank/services/m/integration/new
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
TOCHKA_REDIRECT_URI=http://localhost:3000/api/auth/tochka/callback

# Т-Банк tokens are stored per-account in database
# Connect via POST /api/auth/tbank with token from T-Business dashboard
