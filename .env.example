# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goal_dashboard

# Better Auth (required)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-character-secret-key-here-change-me
BETTER_AUTH_URL=http://localhost:3000

# Encryption key for bank tokens (required, min 32 chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=your-encryption-key-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bank tokens are entered via UI, no env vars needed
# - Точка: JWT token from "Интеграции и API" section
# - Т-Банк: API token from T-Business dashboard
